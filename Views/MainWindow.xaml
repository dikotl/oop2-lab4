<Window
    x:Class="ServiceMarketplace.Views.MainWindow"
    x:Name="RootWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:ServiceMarketplace.ViewModels"
    mc:Ignorable="d"
    Title="Service Marketplace"
    Height="400"
    MinHeight="400"
    Width="600"
    MinWidth="600">

    <!-- Set a data context to the main view-model -->
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0"
            Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Text="Bureau"
                FontSize="16"
                FontWeight="Bold"
                VerticalAlignment="Center"
                Margin="0,0,10,0"/>

            <ComboBox
                Grid.Column="1"
                ItemsSource="{Binding Bureaus}"
                SelectedItem="{Binding SelectedBureau}"
                DisplayMemberPath="Name"
                FontSize="14"
                Height="30"
                VerticalContentAlignment="Center"/>

            <Button
                Grid.Column="2"
                Content="View Details"
                Command="{Binding BureauDetailsCommand}"
                Width="100"
                Height="30"
                Margin="10,0,0,0"/>
        </Grid>

        <StackPanel
            Grid.Row="1"
            Orientation="Horizontal"
            Margin="0,0,0,15">

            <Button
                Command="{Binding ToggleViewCommand}"
                Width="100"
                Height="30"
                Margin="0,0,10,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter
                            Property="Content"
                            Value="View Executors"/>
                        <Style.Triggers>
                            <DataTrigger
                                Binding="{Binding IsViewingExecutors}"
                                Value="True">
                                <Setter
                                    Property="Content"
                                    Value="View Orders"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button
                Content="Import JSON"
                Command="{Binding LoadDataBaseCommand}"
                Background="#fff3cd"
                Width="100"
                Height="30"
                Margin="0,0,10,0"/>

            <Button
                Content="Export JSON"
                Command="{Binding SaveDataBaseCommand}"
                Background="#d4edda"
                Width="100"
                Height="30"/>
        </StackPanel>

        <StackPanel
            Grid.Row="2"
            Orientation="Horizontal"
            Margin="0,0,0,15">

            <Button
                Width="100"
                Height="30"
                Margin="0,0,10,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter
                            Property="Content"
                            Value="New Order"/>
                        <Setter
                            Property="Command"
                            Value="{Binding AddOrderCommand}"/>
                        <Style.Triggers>
                            <DataTrigger
                                Binding="{Binding IsViewingExecutors}"
                                Value="True">
                                <Setter
                                    Property="Content"
                                    Value="New Executor"/>
                                <Setter
                                    Property="Command"
                                    Value="{Binding AddExecutorCommand}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button
                Width="100"
                Height="30"
                Margin="0,0,10,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter
                            Property="Content"
                            Value="Edit Order"/>
                        <Setter
                            Property="Command"
                            Value="{Binding EditOrderCommand}"/>
                        <Style.Triggers>
                            <DataTrigger
                                Binding="{Binding IsViewingExecutors}"
                                Value="True">
                                <Setter
                                    Property="Content"
                                    Value="Edit Executor"/>
                                <Setter
                                    Property="Command"
                                    Value="{Binding EditExecutorCommand}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button
                Width="100"
                Height="30"
                Margin="0,0,10,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter
                            Property="Content"
                            Value="Delete Order"/>
                        <Setter
                            Property="Command"
                            Value="{Binding DeleteOrderCommand}"/>
                        <Style.Triggers>
                            <DataTrigger
                                Binding="{Binding IsViewingExecutors}"
                                Value="True">
                                <Setter
                                    Property="Content"
                                    Value="Delete Executor"/>
                                <Setter
                                    Property="Command"
                                    Value="{Binding DeleteExecutorCommand}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button
                Content="View Details"
                Command="{Binding ViewDetailsCommand}"
                Width="100"
                Height="30"
                Margin="0,0,10,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter
                            Property="Visibility"
                            Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger
                                Binding="{Binding IsViewingExecutors}"
                                Value="True">
                                <Setter
                                    Property="Visibility"
                                    Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <ListView
            Grid.Row="3"
            ItemsSource="{Binding SelectedBureau.Orders}"
            SelectedItem="{Binding SelectedOrder}"
            SelectionMode="Single">

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter
                        Property="HorizontalContentAlignment"
                        Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.Style>
                <Style TargetType="ListView">
                    <Setter
                        Property="Visibility"
                        Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger
                            Binding="{Binding IsViewingExecutors}"
                            Value="True">
                            <Setter
                                Property="Visibility"
                                Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.Style>

            <ListView.View>
                <GridView>
                    <GridViewColumn
                        Header="Status"
                        Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox
                                    ItemsSource="{Binding DataContext.OrderStatuses, ElementName=RootWindow}"
                                    SelectedItem="{Binding Status, UpdateSourceTrigger=PropertyChanged}"
                                    HorizontalAlignment="Stretch"
                                    Margin="2"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn
                        Header="Date"
                        Width="90">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Text="{Binding CreationDate, StringFormat=d}"
                                    TextAlignment="Center"
                                    HorizontalAlignment="Stretch"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn
                        Header="Service Type"
                        Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Text="{Binding Service}"
                                    TextAlignment="Center"
                                    HorizontalAlignment="Stretch"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn
                        Header="Executor"
                        Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Text="{Binding Executor}"
                                    TextAlignment="Center"
                                    HorizontalAlignment="Stretch"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn
                        Header="Cost"
                        Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Text="{Binding Cost, StringFormat=c}"
                                    TextAlignment="Center"
                                    HorizontalAlignment="Stretch"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <ListView
            Grid.Row="3"
            ItemsSource="{Binding SelectedBureau.Staff}"
            SelectedItem="{Binding SelectedExecutor}"
            SelectionMode="Single">

            <ListView.Style>
                <Style TargetType="ListView">
                    <Setter
                        Property="Visibility"
                        Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger
                            Binding="{Binding IsViewingExecutors}"
                            Value="True">
                            <Setter
                                Property="Visibility"
                                Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.Style>

            <ListView.View>
                <GridView>
                    <GridViewColumn
                        Header="First Name"
                        DisplayMemberBinding="{Binding FirstName}"
                        Width="120"/>
                    <GridViewColumn
                        Header="Last Name"
                        DisplayMemberBinding="{Binding LastName}"
                        Width="120"/>
                    <GridViewColumn
                        Header="Birthday"
                        DisplayMemberBinding="{Binding Birthday}"
                        Width="100"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
