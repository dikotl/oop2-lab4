<Window x:Class="ServiceMarketplace.Views.ConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm Action"
        Width="350"
        MinWidth="350"
        Height="150"
        MinHeight="150"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Text="{Binding Text}"
            TextWrapping="Wrap"
            FontSize="14"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"/>

        <StackPanel
            Grid.Row="1"
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            Margin="0,15,0,0">

            <Button
                Content="Yes"
                Command="{Binding YesCommand}"
                Width="75"
                Height="25"
                Margin="0,0,10,0"
                IsDefault="True"/>

            <Button
                Content="No"
                Width="75"
                Height="25"
                IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
